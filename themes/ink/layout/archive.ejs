<%
  const archiveTitle = page.category
    ? '分类：' + page.category
    : page.tag
      ? '标签：' + page.tag
      : '归档';
  let currentYear = '';
%>
<header class="page-header">
  <h1><%= archiveTitle %></h1>
</header>

<section class="archive-list">
  <% page.posts.each(function(post) { %>
    <%
      const postYear = date(post.date, 'YYYY');
      if (postYear !== currentYear) {
        currentYear = postYear;
    %>
      <h2><%= currentYear %></h2>
    <% } %>
    <article>
      <time datetime="<%= date_xml(post.date) %>"><%= date(post.date, 'MM-DD') %></time>
      <a href="<%= url_for(post.path) %>"><%= post.title || '无题' %></a>
    </article>
  <% }); %>
</section>

<nav class="pagination" aria-label="分页">
  <%- paginator({ prev_text: '←', next_text: '→' }) %>
</nav>
