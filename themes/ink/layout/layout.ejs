<%
  /* ---- page title ---- */
  let pageTitle = page.title;
  if (!pageTitle && is_archive()) {
    pageTitle = page.category
      ? '分类：' + page.category
      : page.tag
        ? '标签：' + page.tag
        : '归档';
  }
  if (page.current && page.current > 1) {
    pageTitle = (pageTitle || config.title) + ' · 第 ' + page.current + ' 页';
  }
  const documentTitle = pageTitle
    ? pageTitle + ' · ' + config.title
    : config.title;

  /* ---- description ---- */
  const rawDescription =
    page.description ||
    page.excerpt ||
    ((is_post() || is_page()) && page.content ? page.content : '') ||
    config.description ||
    '';
  const metaDescription = truncate(
    strip_html(rawDescription).replace(/\s+/g, ' ').trim(),
    { length: 160 }
  );

  /* ---- canonical / open graph ---- */
  const canonicalUrl = page.path
    ? full_url_for(page.path).replace(/index\.html$/, '')
    : config.url;
  let ogImage = '';
  if ((is_post() || is_page()) && page.content) {
    const imgMatch = page.content.match(/<img[^>]+src="([^"]+)"/);
    if (imgMatch) ogImage = full_url_for(imgMatch[1]);
  }

  /* ---- feed ---- */
  const atomFeed = config.feed && config.feed.atom;
  const feedPath = atomFeed && atomFeed.enable !== false
    ? atomFeed.output || 'atom.xml'
    : '';
  const assetVersion = theme.asset_version
    ? '?v=' + encodeURIComponent(String(theme.asset_version))
    : '';

  /* ---- math (KaTeX vendored under themes/ink/source/vendor/katex) ---- */
  const needsMath = (is_post() || is_page()) &&
    typeof page.content === 'string' &&
    page.content.indexOf('$') !== -1;

  /* ---- nav ---- */
  const currentPath = '/' + (page.path || '').replace(/index\.html$/, '');
  const isCurrentNav = (target) => {
    const t = url_for(target);
    if (t === '/') return currentPath === '/';
    return currentPath === t || currentPath.startsWith(t.replace(/\/$/, '') + '/');
  };
%>
<!doctype html>
<html lang="<%= config.language || 'zh-CN' %>">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <script>
    (function () {
      var stored = null;
      try { stored = localStorage.getItem('ink-theme'); } catch (e) {}
      var media = window.matchMedia('(prefers-color-scheme: dark)');
      var theme = stored === 'light' || stored === 'dark'
        ? stored
        : (media.matches ? 'dark' : 'light');
      var root = document.documentElement;
      root.setAttribute('data-theme', theme);
      if (!stored && media.addEventListener) {
        media.addEventListener('change', function (event) {
          root.setAttribute('data-theme', event.matches ? 'dark' : 'light');
          var meta = document.getElementById('meta-theme-color');
          if (meta) meta.content = event.matches ? '#141519' : '#f6f5f2';
        });
      }
      document.addEventListener('DOMContentLoaded', function () {
        var meta = document.getElementById('meta-theme-color');
        if (meta && root.getAttribute('data-theme') === 'dark') meta.content = '#141519';
      });
    })();
  </script>
  <title><%= documentTitle %></title>
  <meta name="description" content="<%= metaDescription %>">
  <meta name="author" content="<%= config.author %>">
  <meta name="color-scheme" content="light dark">
  <meta name="theme-color" content="#f6f5f2" id="meta-theme-color">
  <link rel="canonical" href="<%= canonicalUrl %>">
  <meta property="og:site_name" content="<%= config.title %>">
  <meta property="og:title" content="<%= pageTitle || config.title %>">
  <meta property="og:description" content="<%= metaDescription %>">
  <meta property="og:type" content="<%= is_post() ? 'article' : 'website' %>">
  <meta property="og:url" content="<%= canonicalUrl %>">
  <meta property="og:locale" content="zh_CN">
  <% if (ogImage) { %>
    <meta property="og:image" content="<%= ogImage %>">
    <meta name="twitter:card" content="summary_large_image">
  <% } else { %>
    <meta name="twitter:card" content="summary">
  <% } %>
  <% if (is_post() && page.date) { %>
    <meta property="article:published_time" content="<%= date_xml(page.date) %>">
  <% } %>
  <link rel="icon" href="<%= url_for('/images/favicon.ico') %>">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@400;500;600;700&amp;family=Source+Serif+4:opsz,wght@8..60,400;8..60,500;8..60,600;8..60,700&amp;display=swap" rel="stylesheet">
  <% if (feedPath) { %>
    <link rel="alternate" type="application/atom+xml" title="<%= config.title %>" href="<%= url_for(feedPath) %>">
  <% } %>
  <% if (needsMath) { %>
    <link rel="stylesheet" href="<%- url_for('vendor/katex/katex.min.css') + assetVersion %>">
  <% } %>
  <link rel="stylesheet" href="<%- url_for('css/style.css') + assetVersion %>">
</head>
<body class="site-shell">
  <a class="skip-link" href="#main">跳到正文</a>

  <div class="ambient-background" aria-hidden="true">
    <span class="ambient-glow ambient-glow--pointer"></span>
    <span class="ambient-glow ambient-glow--blue"></span>
    <span class="ambient-glow ambient-glow--warm"></span>
  </div>

  <header class="site-header">
    <div class="container header-inner">
      <a class="site-title" href="<%= url_for('/') %>"><%= config.title %></a>
      <div class="header-tools">
        <nav class="site-nav" aria-label="主导航">
          <% Object.keys(theme.menu || {}).forEach(function(label) { %>
            <a href="<%= url_for(theme.menu[label]) %>"<%- isCurrentNav(theme.menu[label]) ? ' aria-current="page"' : '' %>><%= label %></a>
          <% }); %>
        </nav>
        <button class="theme-toggle" type="button" aria-label="切换深浅色模式" title="切换深浅色模式">
          <svg class="icon-sun" viewBox="0 0 24 24" width="16" height="16" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
            <circle cx="12" cy="12" r="4.4"></circle>
            <path d="M12 2.8v2.2M12 19v2.2M2.8 12h2.2M19 12h2.2M5.2 5.2l1.6 1.6M17.2 17.2l1.6 1.6M18.8 5.2l-1.6 1.6M6.8 17.2l-1.6 1.6"></path>
          </svg>
          <svg class="icon-moon" viewBox="0 0 24 24" width="16" height="16" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20.4 14.2A8.6 8.6 0 0 1 9.8 3.6a8.6 8.6 0 1 0 10.6 10.6Z"></path>
          </svg>
        </button>
      </div>
    </div>
  </header>

  <main class="container" id="main">
    <%- body %>
  </main>

  <footer class="site-footer">
    <div class="container footer-inner">
      <span>© <%= new Date().getFullYear() %> <%= config.author %></span>
      <nav class="footer-links" aria-label="页脚链接">
        <% if (feedPath) { %>
          <a href="<%= url_for(feedPath) %>">RSS</a>
        <% } %>
        <% if (theme.footer && theme.footer.github) { %>
          <a href="<%= theme.footer.github %>" rel="me noopener" target="_blank">GitHub</a>
        <% } %>
      </nav>
    </div>
  </footer>

  <button class="back-top" type="button" aria-label="回到顶部" title="回到顶部" hidden>
    <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M12 19V5M5.5 11.5 12 5l6.5 6.5"></path>
    </svg>
  </button>

  <script src="<%- url_for('js/ambient.js') + assetVersion %>"></script>
  <script defer src="<%- url_for('js/main.js') + assetVersion %>"></script>
  <% if (needsMath) { %>
    <script defer src="<%- url_for('vendor/katex/katex.min.js') + assetVersion %>"></script>
    <script defer src="<%- url_for('js/math.js') + assetVersion %>"></script>
  <% } %>
</body>
</html>
